# Build artifacts
desktop/build/
desktop/dist/
build/
dist/
*.spec.bak

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store

# App runtime logs / caches
.otdrSuite/

# Error-report webhook URL — baked into the build at CI time from the
# SLACK_ERROR_WEBHOOK secret. NEVER commit it: the repo is public and Slack
# auto-revokes webhooks found in public source.
_webhook.cfg
desktop/_webhook.cfg

# Local sample data (don't commit OTDR acquisition folders / large data)
*.sor
*.trc
SecretSauce_reports/

# Keep the small committed test fixtures (real SOR data, <2 MB)
!desktop/tests/fixtures/
!desktop/tests/fixtures/**

# Generated report outputs must never be committed, even under fixtures/
desktop/tests/fixtures/**/SpliceReport/
desktop/tests/fixtures/**/SecretSauce_reports/

# CI-written build stamp (bundled into the exe by the specs; never committed —
# a committed copy would masquerade as a real build's identity in dev runs)
version.json
